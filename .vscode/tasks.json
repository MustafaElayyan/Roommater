{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "flutter: pub get",
      "type": "shell",
      "command": "flutter pub get",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "flutter: build",
      "type": "shell",
      "command": "flutter build apk --debug",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "flutter: analyze",
      "type": "shell",
      "command": "flutter analyze",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "flutter: test",
      "type": "shell",
      "command": "flutter test",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "dotnet: restore API",
      "type": "shell",
      "command": "dotnet restore Roommater.API/Roommater.API.csproj",
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: build API",
      "type": "shell",
      "command": "dotnet build Roommater.API/Roommater.API.csproj",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: run API",
      "type": "shell",
      "command": "dotnet run --project Roommater.API/Roommater.API.csproj",
      "group": "none",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "dotnet: ef update database",
      "type": "shell",
      "command": "dotnet ef database update --project Roommater.API/Roommater.API.csproj",
      "group": "none",
      "problemMatcher": []
    }
  ]
}
